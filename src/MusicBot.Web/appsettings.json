{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/musicbot-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=musicbot.db"
  },
  "Spotify": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://127.0.0.1:3050/api/auth/spotify/callback"
  },
  "TikTok": {
    "Username": "",
    "UserSlug": "",
    "SigningServerUrl": "",
    "SigningServerApiKey": "",
    "SessionId": ""
  },
  "Twitch": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:3050/api/auth/twitch/callback"
  },
  "Queue": {
    "MaxSize": 50,
    "MaxSongsPerUser": 10,
    "VotingEnabled": false,
    "PresenceCheckEnabled": false
  },
  "MusicLibrary": {
    "LibraryPath": "music-library",
    "YtDlpPath": "yt-dlp",
    "UseNativeAudioFormat": true
  },
  "Kick": {
    "Channel": "",
    "UserSlug": "",
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:3050/api/auth/kick/callback"
  },
  "Relay": {
    "Url": "",
    "ApiKey": ""
  },
  "Desktop": {
    "OpenLogOnStart": false
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://127.0.0.1:3050"
      }
    }
  }
}
