<Window x:Class="MusicBot.Desktop.UpdateReadyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MusicBot — Actualización disponible"
        Width="540" Height="460"
        MinWidth="420" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F8FAFC"
        Foreground="#1E293B"
        Topmost="True"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#8B5CF6"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderBrush"     Value="#8B5CF6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="20,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7C3AED"/>
                                <Setter Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#475569"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="20,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,18">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="42" Height="42" CornerRadius="10" Background="#EDE9FE" Margin="0,0,14,0">
                    <TextBlock Text="♫" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#7C3AED"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Nueva versión disponible" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <TextBlock x:Name="VersionLabel" FontSize="12" Foreground="#8B5CF6" Margin="0,3,0,0" FontWeight="Medium"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Notes (WebView2 renders markdown as HTML) -->
        <Border Grid.Row="1" Margin="20,16,20,8">
            <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                    ClipToBounds="True">
                <wv2:WebView2 x:Name="NotesWebView"/>
            </Border>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="LaterButton" Content="Más tarde" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0" Click="OnLater"/>
                <Button x:Name="UpdateButton" Content="Actualizar ahora" Style="{StaticResource PrimaryButton}"
                        Click="OnUpdate"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
