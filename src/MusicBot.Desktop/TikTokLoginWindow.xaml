<Window x:Class="MusicBot.Desktop.TikTokLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MusicBot — Iniciar sesión en TikTok"
        Width="480" Height="700"
        MinWidth="380" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#161B22" Padding="16,10">
            <StackPanel>
                <TextBlock Text="Iniciar sesión en TikTok"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#E6EDF3"/>
                <TextBlock x:Name="StatusText"
                           Text="Cargando TikTok…"
                           FontSize="12"
                           Foreground="#8B949E"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- WebView2 — ocupa toda la fila -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>
    </Grid>
</Window>
