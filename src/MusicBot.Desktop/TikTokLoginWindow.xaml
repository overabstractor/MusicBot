<Window x:Class="MusicBot.Desktop.TikTokLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MusicBot — Iniciar sesión en TikTok"
        Width="480" Height="700"
        MinWidth="380" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#161B22" Padding="16,10">
            <StackPanel>
                <TextBlock Text="Iniciar sesión en TikTok"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#E6EDF3"/>
                <TextBlock x:Name="StatusText"
                           Text="Inicia sesión con tu cuenta de TikTok. Las cookies se guardarán automáticamente."
                           FontSize="12"
                           Foreground="#8B949E"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- WebView2 + loading overlay -->
        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="WebView"/>

            <!-- Loading overlay — visible while WebView2 initializes -->
            <Border x:Name="LoadingOverlay"
                    Background="#0D1117"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 Width="180" Height="4"
                                 Foreground="#FF004F"
                                 Background="#2D333B"/>
                    <TextBlock x:Name="OverlayLabel"
                               Text="Cargando TikTok…"
                               Foreground="#8B949E"
                               FontSize="13"
                               Margin="0,14,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
